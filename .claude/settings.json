{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \".claude/claude-assets/hooks/svn_jira_transition_hook.py\" 2>/dev/null || true",
            "timeout": 20,
            "statusMessage": "同步 JIRA 状态"
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": [
    "jira-local"
  ]
}
